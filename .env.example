# FieldNotes Environment Configuration
# Copy this to .env and fill in your keys

# ── Required ──────────────────────────────────────────
# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# ── AI Parsing (at least one required) ────────────────
# DeepSeek (cheapest, recommended for MVP)
DEEPSEEK_API_KEY=
# OpenAI (fallback)
OPENAI_API_KEY=

# ── Email (Resend) ────────────────────────────────────
# https://resend.com — free tier: 100 emails/day
RESEND_API_KEY=

# ── Server ────────────────────────────────────────────
# Public URL for Telegram webhook (e.g. https://fieldnotes.ai)
PUBLIC_URL=http://localhost:8765
